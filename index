<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>From Repetitive Task to Mira Skill</title>

<!-- Fonts: Bold Signal preset — Archivo Black + Space Grotesk -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<style>
/* ===========================================
   THEME — Bold Signal (dark with colored card focal)
   =========================================== */
:root {
    --bg-primary: #1a1a1a;
    --bg-gradient: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 50%, #1a1a1a 100%);
    --card-orange: #F59E0B;
    --card-blue: #2563eb;
    --card-green: #16a34a;
    --card-purple: #9333ea;
    --card-yellow: #facc15;
    --card-pink: #ec4899;
    --card-teal: #0ea5e9;
    --text-primary: #ffffff;
    --text-secondary: rgba(255,255,255,0.6);
    --text-on-card: #1a1a1a;
    --border-subtle: rgba(255,255,255,0.08);

    --font-display: "Archivo Black", sans-serif;
    --font-body: "Space Grotesk", sans-serif;

    --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    --duration-normal: 0.7s;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
}

/* === Mandatory viewport-base.css === */
html, body { height: 100%; overflow-x: hidden; }
html { scroll-snap-type: y mandatory; scroll-behavior: smooth; }

.slide {
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--bg-gradient);
}

.slide-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    max-height: 100%;
    overflow: hidden;
    padding: var(--slide-padding);
}

:root {
    --title-size: clamp(1.5rem, 5vw, 4rem);
    --h2-size: clamp(1.25rem, 3.5vw, 2.5rem);
    --h3-size: clamp(1rem, 2.5vw, 1.75rem);
    --body-size: clamp(0.75rem, 1.5vw, 1.125rem);
    --small-size: clamp(0.65rem, 1vw, 0.875rem);
    --slide-padding: clamp(1rem, 4vw, 3.5rem);
    --content-gap: clamp(0.5rem, 2vw, 1.5rem);
    --element-gap: clamp(0.25rem, 1vw, 0.75rem);
}

.card, .container, .content-box { max-width: min(95vw, 1200px); max-height: min(85vh, 750px); }
.feature-list, .bullet-list { gap: clamp(0.4rem, 1vh, 1rem); }
.feature-list li, .bullet-list li { font-size: var(--body-size); line-height: 1.4; }
.grid { display: grid; gap: clamp(0.5rem, 1.5vw, 1rem); }
img, .image-container { max-width: 100%; max-height: min(50vh, 400px); object-fit: contain; }

@media (max-height: 700px) {
    :root {
        --slide-padding: clamp(0.75rem, 3vw, 2rem);
        --content-gap: clamp(0.4rem, 1.5vw, 1rem);
        --title-size: clamp(1.25rem, 4.5vw, 2.5rem);
        --h2-size: clamp(1rem, 3vw, 1.75rem);
    }
}
@media (max-height: 600px) {
    :root {
        --slide-padding: clamp(0.5rem, 2.5vw, 1.5rem);
        --content-gap: clamp(0.3rem, 1vw, 0.75rem);
        --title-size: clamp(1.1rem, 4vw, 2rem);
        --body-size: clamp(0.7rem, 1.2vw, 0.95rem);
    }
    .nav-dots, .keyboard-hint, .decorative { display: none; }
}
@media (max-width: 600px) {
    :root { --title-size: clamp(1.25rem, 7vw, 2.5rem); }
}

@media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.2s !important; }
    html { scroll-behavior: auto; }
}

/* ===========================================
   ANIMATIONS — staggered reveal
   =========================================== */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity var(--duration-normal) var(--ease-out-expo),
                transform var(--duration-normal) var(--ease-out-expo);
}
.slide.visible .reveal { opacity: 1; transform: translateY(0); }
.reveal:nth-child(1) { transition-delay: 0.05s; }
.reveal:nth-child(2) { transition-delay: 0.15s; }
.reveal:nth-child(3) { transition-delay: 0.25s; }
.reveal:nth-child(4) { transition-delay: 0.35s; }
.reveal:nth-child(5) { transition-delay: 0.45s; }
.reveal:nth-child(6) { transition-delay: 0.55s; }

/* ===========================================
   SHARED — slide chrome (corner labels)
   =========================================== */
.slide-number {
    position: absolute;
    top: clamp(1rem, 2vw, 1.5rem);
    left: clamp(1rem, 3vw, 2.5rem);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.25rem);
    color: var(--text-secondary);
    letter-spacing: 0.1em;
    z-index: 5;
}
.slide-tag {
    position: absolute;
    top: clamp(1rem, 2vw, 1.5rem);
    right: clamp(1rem, 3vw, 2.5rem);
    font-size: clamp(0.6rem, 0.9vw, 0.8rem);
    color: var(--text-secondary);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    z-index: 5;
}

/* ===========================================
   TITLE SLIDE
   =========================================== */
.title-slide {
    align-items: center;
    justify-content: center;
    padding: var(--slide-padding);
    text-align: center;
}
.title-card {
    background: var(--card-orange);
    border-radius: clamp(8px, 1vw, 16px);
    padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 6vw, 5rem);
    color: var(--text-on-card);
    max-width: min(90vw, 900px);
    box-shadow: 0 24px 80px rgba(245, 158, 11, 0.3);
}
.title-card .eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    opacity: 0.7;
}
.title-card h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6.5vw, 5rem);
    line-height: 0.95;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: -0.02em;
}
.title-card .subtitle {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(0.85rem, 1.5vw, 1.2rem);
    line-height: 1.5;
    opacity: 0.85;
}
.title-meta {
    margin-top: clamp(1.5rem, 3vw, 2rem);
    font-size: clamp(0.65rem, 0.9vw, 0.8rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-secondary);
}

/* ===========================================
   SECTION HEADER (slide titles)
   =========================================== */
.slide-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    line-height: 1;
    margin-bottom: clamp(0.5rem, 1.2vw, 1rem);
    letter-spacing: -0.02em;
}
.slide-heading .accent { color: var(--card-orange); }
.slide-lead {
    font-size: clamp(0.85rem, 1.3vw, 1.05rem);
    color: var(--text-secondary);
    margin-bottom: clamp(1rem, 2vw, 1.75rem);
    max-width: 800px;
    line-height: 1.55;
}

/* ===========================================
   PROBLEM SLIDE — 2x2 pain grid
   =========================================== */
.pain-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    flex: 1;
    min-height: 0;
}
.pain-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-left: 3px solid var(--card-orange);
    border-radius: clamp(6px, 0.8vw, 12px);
    padding: clamp(1rem, 2vw, 1.75rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.pain-card .icon {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: clamp(0.5rem, 1vw, 0.75rem);
}
.pain-card h3 {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.6vw, 1.25rem);
    margin-bottom: clamp(0.4rem, 0.8vw, 0.6rem);
    line-height: 1.15;
}
.pain-card p {
    font-size: clamp(0.75rem, 1.1vw, 0.95rem);
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ===========================================
   GOAL SLIDE — side-by-side outputs
   =========================================== */
.goal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
    flex: 1;
    min-height: 0;
}
.goal-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-radius: clamp(8px, 1vw, 14px);
    padding: clamp(0.75rem, 1.5vw, 1.25rem);
    display: flex;
    flex-direction: column;
    min-height: 0;
}
.goal-card .label {
    font-family: var(--font-display);
    font-size: clamp(0.7rem, 1vw, 0.9rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: clamp(0.5rem, 1vw, 0.75rem);
    color: var(--card-orange);
}
.goal-card img {
    width: 100%;
    flex: 1;
    min-height: 0;
    max-height: 100%;
    object-fit: contain;
    border-radius: clamp(4px, 0.5vw, 8px);
    border: 1px solid var(--border-subtle);
    background: #fff;
}

/* ===========================================
   PROCESS SLIDE — 4-step horizontal flow
   =========================================== */
.process-flow {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 1.5vw, 1.25rem);
    flex: 1;
    min-height: 0;
    align-items: stretch;
}
.process-step {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-radius: clamp(8px, 1vw, 14px);
    padding: clamp(1rem, 2vw, 1.75rem);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
}
.process-step::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 4px;
}
.process-step.step-1::before { background: var(--card-blue); }
.process-step.step-2::before { background: var(--card-green); }
.process-step.step-3::before { background: var(--card-orange); }
.process-step.step-4::before { background: var(--card-purple); }

.process-step .num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    line-height: 1;
    margin-bottom: clamp(0.5rem, 1vw, 0.75rem);
}
.step-1 .num { color: var(--card-blue); }
.step-2 .num { color: var(--card-green); }
.step-3 .num { color: var(--card-orange); }
.step-4 .num { color: var(--card-purple); }

.process-step h3 {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    margin-bottom: clamp(0.4rem, 0.8vw, 0.6rem);
    line-height: 1.15;
}
.process-step p {
    font-size: clamp(0.7rem, 1.05vw, 0.9rem);
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ===========================================
   CHAT SLIDES — screenshot + caption layout
   =========================================== */
.chat-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(1rem, 2.5vw, 2rem);
    flex: 1;
    min-height: 0;
    align-items: center;
}
.chat-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.step-badge {
    display: inline-block;
    width: fit-content;
    font-family: var(--font-display);
    font-size: clamp(0.65rem, 0.95vw, 0.8rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: clamp(0.3rem, 0.6vw, 0.45rem) clamp(0.7rem, 1.2vw, 1rem);
    color: var(--text-on-card);
    border-radius: clamp(4px, 0.5vw, 6px);
    margin-bottom: clamp(0.6rem, 1.2vw, 1rem);
}
.step-badge.b1 { background: var(--card-blue); color: #fff; }
.step-badge.b2 { background: var(--card-green); color: #fff; }
.step-badge.b3 { background: var(--card-orange); }

.chat-text h2 {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.2vw, 2.4rem);
    line-height: 1.05;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
    letter-spacing: -0.01em;
}
.chat-text p {
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    color: var(--text-secondary);
    line-height: 1.6;
}
.chat-text p strong {
    color: var(--text-primary);
    font-weight: 600;
}
.chat-img-wrap {
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 0;
}
.chat-img-wrap img {
    max-height: min(78vh, 700px);
    max-width: 100%;
    border-radius: clamp(6px, 0.8vw, 12px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
    border: 1px solid var(--border-subtle);
}

/* ===========================================
   PARAMS SLIDE — two batches side by side
   =========================================== */
.params-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
    flex: 1;
    min-height: 0;
}
.param-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-radius: clamp(8px, 1vw, 14px);
    padding: clamp(0.85rem, 1.5vw, 1.25rem);
    display: flex;
    flex-direction: column;
    min-height: 0;
}
.param-card .pill {
    font-family: var(--font-display);
    font-size: clamp(0.65rem, 0.95vw, 0.8rem);
    padding: clamp(0.25rem, 0.5vw, 0.4rem) clamp(0.7rem, 1.2vw, 0.9rem);
    border-radius: clamp(4px, 0.5vw, 6px);
    width: fit-content;
    margin-bottom: clamp(0.5rem, 1vw, 0.75rem);
    letter-spacing: 0.1em;
}
.pill.us { background: var(--card-blue); color: #fff; }
.pill.nz { background: var(--card-pink); color: #fff; }
.param-card img {
    width: 100%;
    flex: 1;
    min-height: 0;
    max-height: 100%;
    object-fit: contain;
    border-radius: clamp(4px, 0.5vw, 8px);
    border: 1px solid var(--border-subtle);
    background: #fff;
}
.param-card .note {
    margin-top: clamp(0.5rem, 1vw, 0.75rem);
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    color: var(--text-secondary);
    line-height: 1.5;
}
.param-card .note strong { color: var(--card-orange); }
.highlight {
    background: rgba(245, 158, 11, 0.2);
    color: var(--card-orange);
    padding: 0 4px;
    border-radius: 3px;
    font-weight: 600;
}

/* ===========================================
   PACKAGE SLIDE — formula visual
   =========================================== */
.package-formula {
    display: flex;
    align-items: stretch;
    gap: clamp(0.5rem, 1.5vw, 1.5rem);
    flex: 1;
    min-height: 0;
    justify-content: center;
}
.package-piece {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-radius: clamp(8px, 1vw, 14px);
    padding: clamp(1rem, 2vw, 1.75rem);
    flex: 1;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    text-align: center;
    justify-content: center;
}
.package-piece.final {
    background: var(--card-orange);
    color: var(--text-on-card);
    border: none;
    box-shadow: 0 16px 48px rgba(245,158,11,0.3);
}
.package-piece .icon {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(0.5rem, 1vw, 0.75rem);
}
.package-piece h3 {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.6vw, 1.25rem);
    margin-bottom: clamp(0.3rem, 0.6vw, 0.5rem);
}
.package-piece p {
    font-size: clamp(0.7rem, 1.05vw, 0.9rem);
    color: var(--text-secondary);
    line-height: 1.5;
}
.package-piece.final p { color: rgba(0,0,0,0.7); }
.package-op {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--text-secondary);
    align-self: center;
}

/* ===========================================
   TAKEAWAY SLIDE — numbered list
   =========================================== */
.takeaway-list {
    display: flex;
    flex-direction: column;
    gap: clamp(0.6rem, 1.2vw, 1rem);
    flex: 1;
    min-height: 0;
    justify-content: center;
    max-width: 900px;
}
.takeaway-item {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border-subtle);
    border-radius: clamp(6px, 0.8vw, 12px);
    padding: clamp(0.85rem, 1.5vw, 1.25rem);
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 1.5vw, 1.25rem);
}
.takeaway-item .num {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    line-height: 1;
    color: var(--card-orange);
    width: clamp(40px, 5vw, 60px);
    flex-shrink: 0;
    text-align: center;
}
.takeaway-item h3 {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    margin-bottom: clamp(0.2rem, 0.4vw, 0.35rem);
}
.takeaway-item p {
    font-size: clamp(0.75rem, 1.1vw, 0.95rem);
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ===========================================
   END SLIDE
   =========================================== */
.end-slide {
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--slide-padding);
}
.end-slide h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5.5vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: clamp(1rem, 2vw, 1.5rem);
    max-width: 1100px;
}
.end-slide h1 .accent { color: var(--card-orange); }
.end-slide .tagline {
    font-size: clamp(0.95rem, 1.6vw, 1.3rem);
    color: var(--text-secondary);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 700px;
    line-height: 1.5;
}
.end-slide .signature {
    font-family: var(--font-body);
    font-size: clamp(0.65rem, 0.95vw, 0.8rem);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-secondary);
    opacity: 0.6;
}

/* ===========================================
   PROGRESS BAR & NAV DOTS
   =========================================== */
.progress-bar {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    background: var(--card-orange);
    transition: width 0.4s ease;
    z-index: 100;
}
.nav-dots {
    position: fixed;
    right: clamp(0.75rem, 1.5vw, 1.5rem);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: clamp(0.4rem, 0.8vw, 0.7rem);
    z-index: 100;
}
.nav-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
}
.nav-dot:hover { background: rgba(255,255,255,0.5); }
.nav-dot.active {
    background: var(--card-orange);
    transform: scale(1.4);
}
.keyboard-hint {
    position: fixed;
    bottom: clamp(0.75rem, 1.5vw, 1.5rem);
    left: clamp(0.75rem, 1.5vw, 1.5rem);
    font-size: clamp(0.6rem, 0.85vw, 0.7rem);
    color: var(--text-secondary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    z-index: 100;
    opacity: 0.5;
}
</style>
</head>
<body>

<div class="progress-bar"></div>
<nav class="nav-dots" aria-label="Slide navigation"></nav>
<div class="keyboard-hint">↑ ↓ or scroll</div>

<!-- ============================================
     SLIDE 1: TITLE
     ============================================ -->
<section class="slide title-slide">
    <span class="slide-number reveal">01 / 11</span>
    <span class="slide-tag reveal">A Field Note</span>
    <div class="title-card reveal">
        <div class="eyebrow">A field note on vibe coding</div>
        <h1>From Repetitive Task<br>to Mira Skill</h1>
        <p class="subtitle">How I turned a manual QA dashboard process into something Mira can do for me — every batch, every time.</p>
    </div>
    <div class="title-meta reveal">May 2026 · Tako Survey RM</div>
</section>

<!-- ============================================
     SLIDE 2: THE PROBLEM
     ============================================ -->
<section class="slide">
    <span class="slide-number">02 / 11</span>
    <span class="slide-tag">The problem</span>
    <div class="slide-content">
        <h2 class="slide-heading reveal">The <span class="accent">problem.</span></h2>
        <p class="slide-lead reveal">Every batch of evaluation data, the same dashboard. Built by hand. Every time.</p>
        <div class="pain-grid">
            <div class="pain-card reveal">
